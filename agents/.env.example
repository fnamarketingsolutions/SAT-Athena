ANTHROPIC_API_KEY=sk-ant-...

# Supabase (for content generation workflow)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Micro-lesson generation pipeline ───────────────────────────────────
# Production stack: c2-ir prompt + tool-use schema + self-critique pass.
# The deterministic near-duplicate collapse runs automatically inside
# the IR path (no flag). Leaving these unset falls back to the legacy
# baseline prompt, which is structurally weaker; set them in any
# environment that serves real users.

# Selects the c2-ir prompt under agents/prompts/micro_lesson/. Required
# for the structured-output path below to behave correctly — the c2-ir
# prompt is authored for that schema.
MICROLESSON_PROMPT_VARIANT=c2-ir

# Forces the model to emit a LessonOutputSchema object (Anthropic
# structured-output / tool-use). Without this, c2-ir would fall back
# to prose emission and produce malformed steps.
MICROLESSON_TOOL_USE=1

# Adds a second LLM pass (~one round-trip) that reviews the generated
# lesson against the contract rules and rewrites violating steps.
# Roughly time-neutral on average; trades latency for quality.
MICROLESSON_SELF_CRITIQUE=1

# Routes the /mentor chat's "solve this equation" turns through the same
# structured IR path the micro-lesson uses, so they render as
# APPLY/COLLAPSE/STATE triplet morphs instead of ad-hoc write_text/write_math.
# An intent gate keeps all other mentor turns (motivation, progress,
# concepts, image-confirm) on the unchanged prose stream. Unset → mentor
# stays prose-only (clean rollback).
MENTOR_TOOL_USE=1

# ── Majordomo gateway ─────────────────────────────────────────────────
# Routes 100% of LLM traffic through gomajordomo.com for cost
# attribution, replay, and evals. See app/utils/llm_client.py and
# context/project/majordomo-integration.md.
#
# Set MAJORDOMO_ENABLED=0 to bypass the gateway and hit Anthropic /
# OpenAI directly. This is a kill switch for incident response — do
# NOT use it as a routine bypass.
MAJORDOMO_ENABLED=1
MAJORDOMO_GATEWAY_URL=https://gateway.gomajordomo.com
MAJORDOMO_SERVICE=athena-agents
# `development` | `staging` | `production` | `studio` — used for
# per-environment cost breakdowns in the Majordomo dashboard. The
# value is also used as the suffix on Keychain entry names (see below).
MAJORDOMO_ENVIRONMENT=development

# ─── Video-intro pipeline: per-step model overrides ─────────────────
#
# The video_intro pipeline issues six LLM calls per video — brief
# generation, composition sketch, static SVG author, living-treatment
# author, code revise (on failure), and vision critique. Each has a
# different task profile; the right model differs per step.
#
# Defaults (all unset → fall back to claude-sonnet-4-6) preserve
# all-Sonnet behavior. Override per step here for production:
#
#   reasoning-heavy   → BRIEF, SKETCH, CRITIQUE  → use Opus-tier
#   code-emission     → AUTHOR (and revise)      → Sonnet is sweet spot
#
# Cost note: bumping the three reasoning steps to Opus roughly doubles
# the per-video cost (vs all-Sonnet) — typically $0.40 → $0.80 with one
# new primitive. Worth it for production quality; toggle off (unset
# vars) for fast iteration on prompts.
#
# Use minor-versioned aliases (e.g. claude-sonnet-4-6, not
# claude-sonnet-4) — bare-major aliases return 404 on the gateway.

# VIDEO_INTRO_MODEL_BRIEF=claude-opus-4-6
# VIDEO_INTRO_MODEL_SKETCH=claude-opus-4-6
# VIDEO_INTRO_MODEL_AUTHOR=claude-sonnet-4-6
# VIDEO_INTRO_MODEL_CRITIQUE=claude-opus-4-6

# MAJORDOMO_API_KEY (and other secrets — ANTHROPIC_API_KEY,
# ELEVENLABS_*, SUPABASE_SERVICE_ROLE_KEY, …) are not templated here.
# Pull them via the vault CLI:
#
#   vault sync athena-agent -e development -f agents/.env
#
# That writes the `athena-agent` collection's key/value pairs into this
# file. One collection for all envs for now; we'll split env namespaces
# inside the collection when we need them. See app/utils/README.md for
# the full pattern + ~/secrets/ for the CLI source.
#
# Prod (Northflank): set secrets directly in the deploy's secret store;
# `vault sync` is dev-only.
