{
  "name": "video-intro-remotion",
  "version": "0.1.0",
  "private": true,
  "description": "Remotion compositor for Athena intro/motivator videos — consumes a manifest derived from a brief and renders an MP4. White-line-on-black aesthetic, KaTeX-rendered math overlays.",
  "scripts": {
    "dev": "remotion studio src/index.ts",
    "render": "remotion render src/index.ts IntroVideo out/intro.mp4",
    "render:ex1": "remotion render src/index.ts IntroVideo out/ex1.mp4 --props=./manifests/ex1-stub.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@remotion/cli": "4.0.336",
    "@remotion/bundler": "4.0.336",
    "@remotion/renderer": "4.0.336",
    "@remotion/media-utils": "4.0.336",
    "katex": "0.16.10",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "remotion": "4.0.336"
  },
  "devDependencies": {
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "typescript": "5.7.2"
  }
}
